{
  "headers": [
    {
      "source": "/api/admin/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, max-age=30"
        },
        {
          "key": "X-Cache-Type",
          "value": "admin"
        }
      ]
    },
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, s-maxage=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/:path*",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/admin/stats",
      "schedule": "*/5 * * * *"
    }
  ]
}
